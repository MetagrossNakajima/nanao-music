---
import '../styles/global.css';

type Props = {
	title?: string;
	description?: string;
	type?: 'website' | 'article';
	jsonLd?: unknown;
};

const siteName = 'ナナヲアカリ コール セトリまとめ';
const {
	title = siteName,
	description = 'ナナヲアカリのライブ・イベントのセトリやコール情報を曲名や会場名で検索できるまとめサイトです。',
	type = 'website',
	jsonLd,
} = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const jsonLdText = jsonLd ? JSON.stringify(jsonLd).replaceAll('<', '\\u003c') : undefined;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="ja_JP" />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{jsonLdText && <script type="application/ld+json" set:html={jsonLdText} />}
	</head>
	<body>
		<slot />
	</body>
</html>
