---
import type { CallCategory } from "../data/callTypes"
import SectionHeading from "./SectionHeading.astro"

type Props = {
  categories: CallCategory[]
}

const { categories } = Astro.props
---

<section class="mt-6" aria-label="コールカテゴリー">
  <div class="mb-4">
    <SectionHeading>コールカテゴリー</SectionHeading>
  </div>
  <div class="grid gap-5 border-t border-[#e6e6e6]">
    {
      categories.map((category) => (
        <section
          id={category.id}
          class="border-b border-[#e6e6e6] bg-white py-4"
        >
          <h2 class="text-[20px] leading-normal font-bold tracking-[0.02em]">
            {category.title}
          </h2>
          {category.items.length > 0 ? (
            <ul class="mt-3 grid list-none gap-2 p-0">
              {category.items.map((item) => (
                <li class="text-[17px] leading-[1.7] font-normal tracking-[0.02em]">
                  {item}
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-2 text-[16px] leading-[1.7] font-normal tracking-[0.02em] text-[#777]">
              特になし
            </p>
          )}
        </section>
      ))
    }
  </div>
</section>
