---
import type { Setlist } from "../data/setlistTypes"
import { resolveSong } from "../data/songResolver"
import Badge from "./Badge.astro"

type Props = {
  setlist: Setlist
}

const { setlist } = Astro.props

const tagLabels = {
  medley: "メドレー",
}
---

<div>
  <ol class="grid list-none gap-0 border-t border-[#e6e6e6] p-0">
    {
      setlist.songs.map((song) => {
        const songNumber = song.position
        const songInfo = resolveSong(song.songId)

        return (
          <li class="grid items-center gap-2 border-b border-[#e6e6e6] bg-white px-1 py-3.5 grid-cols-[24px_1fr_60px]">
            <span class="text-[16px] leading-[1.7] font-bold tracking-[0.02em] text-[#777]">
              {String(songNumber).padStart(2, "0")}
            </span>
            <span class="text-[17px] leading-[1.7] font-bold tracking-[0.02em]">
              {songInfo.title}
              {song.tags.length > 0 && (
                <span class="ml-2.5 inline-flex flex-wrap gap-1.5 align-middle">
                  {song.tags.map((tag) => (
                    <Badge tone="accent">{tagLabels[tag]}</Badge>
                  ))}
                </span>
              )}
            </span>
            {songInfo.itunesPreviewUrl && (
              <button
                type="button"
                class="inline-flex w-15 items-center justify-center rounded border border-[#007f73] bg-white px-2 py-1.5 text-[15px] leading-[1.4] font-bold tracking-[0.02em] text-[#007f73] hover:bg-[#f0fbf8]"
                aria-label={`${songInfo.title}を試聴`}
                data-audio-preview
                data-audio-src={songInfo.itunesPreviewUrl}
                data-song-title={songInfo.title}
              >
                試聴
              </button>
            )}
          </li>
        )
      })
    }
  </ol>

  <p
    class="mt-3 hidden text-[15px] leading-[1.7] font-normal tracking-[0.02em] text-[#666]"
    data-audio-status
    aria-live="polite"
  >
  </p>
  <audio data-audio-player preload="none"></audio>
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    "[data-audio-preview]",
  )
  const audio = document.querySelector<HTMLAudioElement>("[data-audio-player]")
  const status = document.querySelector<HTMLElement>("[data-audio-status]")
  let currentSrc = ""

  function setPlayingButton(activeButton?: HTMLButtonElement) {
    for (const button of buttons) {
      const isActive = button === activeButton
      const songTitle = button.dataset.songTitle
      button.textContent = isActive ? "停止" : "試聴"
      button.setAttribute(
        "aria-label",
        songTitle
          ? `${songTitle}${isActive ? "を停止" : "を試聴"}`
          : isActive
            ? "停止"
            : "試聴",
      )
    }
  }

  for (const button of buttons) {
    button.addEventListener("click", async () => {
      const src = button.dataset.audioSrc
      const songTitle = button.dataset.songTitle

      if (!audio || !src) return

      if (currentSrc === src && !audio.paused) {
        audio.pause()
        setPlayingButton()
        return
      }

      audio.src = src
      currentSrc = src

      try {
        await audio.play()
        setPlayingButton(button)

        if (status) {
          status.hidden = false
          status.textContent = songTitle
            ? `${songTitle} を再生中（provided courtesy of iTunes）`
            : "再生中（provided courtesy of iTunes）"
        }
      } catch {
        if (status) {
          status.hidden = false
          status.textContent = "この環境では自動再生できませんでした。"
        }
      }
    })
  }

  audio?.addEventListener("ended", () => {
    setPlayingButton()
  })
</script>
